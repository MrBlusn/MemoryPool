{
  "version": "2.0.0",
  "tasks": [
    {
        "type": "cppbuild",
        "label": "C/C++: Build active file only",
        "command": "C:/msys64/ucrt64/bin/g++.exe",
        "args": [
            "-fdiagnostics-color=always",
            "-g",
            "${file}",
            "-o",
            "${fileDirname}\\${fileBasenameNoExtension}.exe"
        ],
        "options": {
            "cwd": "C:/msys64/ucrt64/bin"
        },
        "problemMatcher": [
            "$gcc"
        ],
        "group": "build"
    },
    {
        "type": "cppbuild",
        "label": "C/C++: Build Unit test",
        "command": "C:/msys64/ucrt64/bin/g++.exe",
        "args": [
            "-fdiagnostics-color=always",
            "-g",
            "-std=c++17",
            "-I",
            "${workspaceFolder}\\include",
            "${workspaceFolder}\\Tests\\Unit.cpp",
            "${workspaceFolder}\\src\\ThreadCache.cpp",
            "${workspaceFolder}\\src\\CentralCache.cpp",
            "${workspaceFolder}\\src\\PageCache.cpp",
            "-o",
            "${workspaceFolder}\\build\\unit_test.exe"
        ],
        "options": {
            "cwd": "${workspaceFolder}"
        },
        "problemMatcher": [
            "$gcc"
        ],
        "group": "build",
        "detail": "编译器: C:/msys64/ucrt64/bin/g++.exe"
    },
    {
        "type": "cppbuild",
        "label": "C/C++: Build Performance test",
        "command": "C:/msys64/ucrt64/bin/g++.exe",
        "args": [
            "-fdiagnostics-color=always",
            "-g",
            "-std=c++17",
            "-I",
            "${workspaceFolder}\\include",
            "${workspaceFolder}\\Tests\\PerformanceTest.cpp",
            "${workspaceFolder}\\src\\ThreadCache.cpp",
            "${workspaceFolder}\\src\\CentralCache.cpp",
            "${workspaceFolder}\\src\\PageCache.cpp",
            "-o",
            "${workspaceFolder}\\build\\performance_test.exe"
        ],
        "options": {
            "cwd": "${workspaceFolder}"
        },
        "problemMatcher": [
            "$gcc"
        ],
        "group": {
            "kind": "build",
            "isDefault": true
        },
        "detail": "编译器: C:/msys64/ucrt64/bin/g++.exe"
    },
    {
        "type": "process",
        "label": "C/C++: Run Performance test",
        "command": "${workspaceFolder}\\build\\performance_test.exe",
        "dependsOn": "C/C++: Build Performance test",
        "problemMatcher": []
    }
]
}
